---
import Icon from './Icon.astro';
import { site } from '../data/site';
import { ui, type Lang } from '../i18n/ui';
interface Props { lang?: Lang }
const { lang = 'tr' } = Astro.props;
const L = ui[lang];
const waHref = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(L.waText)}`;
---
<a class="wa-fab" href={waHref} rel="noopener" target="_blank" aria-label={L.waFabAria}>
  <Icon name="wa" />
</a>

<style>
  .wa-fab {
    position: fixed;
    right: clamp(1rem, 3vw, 1.75rem);
    bottom: clamp(1rem, 3vw, 1.75rem);
    z-index: 60;
    width: 58px;
    height: 58px;
    border-radius: 50%;
    background: #25d366;
    color: #fff;
    display: grid;
    place-items: center;
    box-shadow: 0 8px 24px rgba(37, 211, 102, 0.4);
    transition: transform 0.15s ease, box-shadow 0.2s ease;
  }
  .wa-fab:hover { transform: scale(1.06); box-shadow: 0 10px 30px rgba(37, 211, 102, 0.5); }
  .wa-fab :global(svg) { width: 30px; height: 30px; }
</style>
