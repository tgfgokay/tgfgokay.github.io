---
import Icon from './Icon.astro';
import { site } from '../data/site';
import { ui, type Lang } from '../i18n/ui';
interface Props {
  heading?: string;
  text?: string;
  lang?: Lang;
}
const { lang = 'tr', heading, text } = Astro.props;
const L = ui[lang];
const waHref = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(L.waText)}`;
---
<section class="cta-strip">
  <div class="container inner">
    <div>
      <h2>{heading ?? L.ctaHeading}</h2>
      <p>{text ?? L.ctaText}</p>
    </div>
    <div class="cta-btns">
      <a href={`tel:${site.phone}`} class="btn btn-ghost"><Icon name="phone" /> {site.phoneDisplay}</a>
      <a href={waHref} class="btn btn-wa" rel="noopener" target="_blank"><Icon name="wa" /> {L.waWrite}</a>
    </div>
  </div>
</section>

<style>
  .cta-strip { background: var(--grad); color: #fff; }
  .inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
    padding-block: clamp(2.5rem, 5vw, 3.5rem);
  }
  .inner h2 { color: #fff; margin-bottom: 0.35rem; }
  .inner p { color: rgba(255, 255, 255, 0.9); margin: 0; max-width: 48ch; }
  .cta-btns { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .cta-strip .btn-ghost { background: rgba(255,255,255,0.14); color: #fff; border-color: rgba(255,255,255,0.3); }
  .cta-strip .btn-ghost:hover { background: rgba(255,255,255,0.24); color: #fff; }
</style>
