---
import Icon from './Icon.astro';
import { site } from '../data/site';
import { ui, type Lang } from '../i18n/ui';
interface Props {
  heading?: string;
  eyebrow?: string;
  lang?: Lang;
}
const { lang = 'tr', heading, eyebrow } = Astro.props;
const L = ui[lang];
const waHref = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(L.waText)}`;
const eb = eyebrow === undefined ? L.contactEyebrow : eyebrow;
---
<section class="section" id="iletisim">
  <div class="container">
    {eb && <span class="eyebrow">{eb}</span>}
    <h2>{heading ?? L.contactHeading}</h2>
    <p class="lede">{L.contactLede}</p>

    <div class="contact-grid">
      <div class="info">
        <ul class="info-list">
          <li>
            <span class="icon-badge"><Icon name="pin" /></span>
            <div><strong>{L.addr}</strong><br />{site.address.full}
              <br /><a href={site.mapLink} rel="noopener" target="_blank">{L.openMap}</a></div>
          </li>
          <li>
            <span class="icon-badge"><Icon name="phone" /></span>
            <div><strong>{L.phone}</strong><br />
              <a href={`tel:${site.phone}`}>{site.phoneDisplay}</a> ·
              <a href={`tel:${site.gsm}`}>{site.gsmDisplay}</a></div>
          </li>
          <li>
            <span class="icon-badge"><Icon name="mail" /></span>
            <div><strong>{L.email}</strong><br /><a href={`mailto:${site.email}`}>{site.email}</a></div>
          </li>
          <li>
            <span class="icon-badge"><Icon name="clock" /></span>
            <div><strong>{L.workingHours}</strong><br />{L.hours}</div>
          </li>
        </ul>
        <div class="map">
          <iframe
            src={site.mapEmbed}
            title={L.mapTitle}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          ></iframe>
        </div>
      </div>

      <form class="form card" name="iletisim" method="POST" action="#" data-netlify="false" data-lang={lang}>
        <p class="form-note">{L.formNote}</p>
        <label>{L.fName}
          <input type="text" name="ad" required autocomplete="name" placeholder={L.fNamePh} />
        </label>
        <label>{L.fPhone}
          <input type="tel" name="telefon" required autocomplete="tel" placeholder={L.fPhonePh} />
        </label>
        <label>{L.fSubject}
          <select name="konu">
            {L.fSubjectOpts.map((o) => <option>{o}</option>)}
          </select>
        </label>
        <label>{L.fMessage}
          <textarea name="mesaj" rows="3" placeholder={L.fMessagePh}></textarea>
        </label>
        <button type="submit" class="btn btn-primary">{L.fSend}</button>
        <p class="form-alt">{L.fAlt} <a href={waHref} rel="noopener" target="_blank">{L.fAltLink}</a></p>
      </form>
    </div>
  </div>
</section>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 2rem;
    margin-top: 2rem;
  }
  .info-list { list-style: none; margin: 0 0 1.5rem; padding: 0; display: grid; gap: 1.1rem; }
  .info-list li { display: flex; gap: 0.9rem; align-items: flex-start; }
  .info-list .icon-badge { margin-bottom: 0; flex: none; }
  .info-list strong { color: var(--ink); }
  .info-list div { font-size: 0.95rem; color: var(--slate); }
  .map {
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--line);
    box-shadow: var(--shadow-sm);
  }
  .map iframe { width: 100%; height: 260px; border: 0; display: block; }

  .form { display: grid; gap: 0.85rem; align-content: start; }
  .form-note { font-weight: 600; margin: 0; }
  .form label { display: grid; gap: 0.35rem; font-size: 0.88rem; font-weight: 500; color: var(--ink); }
  .form input, .form select, .form textarea {
    font-family: inherit;
    font-size: 0.98rem;
    padding: 0.7rem 0.85rem;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: var(--white);
    color: var(--ink);
    width: 100%;
  }
  .form input:focus, .form select:focus, .form textarea:focus {
    outline: none;
    border-color: var(--blurple);
    box-shadow: 0 0 0 3px rgba(99, 91, 255, 0.15);
  }
  .form button { margin-top: 0.25rem; justify-content: center; }
  .form-alt { text-align: center; font-size: 0.9rem; color: var(--slate); margin: 0; }
  @media (max-width: 820px) {
    .contact-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  // Form henüz arka uca bağlı değil — kullanıcıyı WhatsApp'a yönlendir (geçici).
  const f = document.querySelector('form[name="iletisim"]') as HTMLFormElement | null;
  f?.addEventListener('submit', (e) => {
    e.preventDefault();
    const data = new FormData(f);
    const ad = (data.get('ad') || '').toString();
    const konu = (data.get('konu') || '').toString();
    const mesaj = (data.get('mesaj') || '').toString();
    const en = f.getAttribute('data-lang') === 'en';
    const txt = en
      ? `Hello, I’m ${ad}. Subject: ${konu}.${mesaj ? ' ' + mesaj : ''}`
      : `Merhaba, ben ${ad}. Konu: ${konu}.${mesaj ? ' ' + mesaj : ''}`;
    window.open(`https://wa.me/905418528604?text=${encodeURIComponent(txt)}`, '_blank');
  });
</script>
