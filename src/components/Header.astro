---
import Logo from './Logo.astro';
import Icon from './Icon.astro';
import { site } from '../data/site';
import { ui, routes, type Lang } from '../i18n/ui';

interface Props { lang?: Lang; altPath?: string }
const { lang = 'tr', altPath } = Astro.props;
const L = ui[lang];
const r = routes[lang];
const otherLang: Lang = lang === 'tr' ? 'en' : 'tr';

const waHref = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(L.waText)}`;
const path = Astro.url.pathname;
const nav = [
  { href: r.services, label: L.nav.services },
  { href: r.guide, label: L.nav.guide },
  { href: r.about, label: L.nav.about },
  { href: r.contact, label: L.nav.contact },
];
const isActive = (href: string) =>
  href === r.home ? path === r.home : path.startsWith(href);
// Dil değiştirici: karşı sayfanın yolu verilmişse ona, yoksa karşı dilin ana sayfasına
const switchHref = altPath ?? routes[otherLang].home;
---

<header class="site-header">
  <div class="container bar">
    <a href={r.home} class="brand" aria-label={L.brandAria}>
      <Logo size={38} />
    </a>

    <nav class="nav" aria-label={L.navAria}>
      {nav.map((n) => (
        <a href={n.href} class:list={['nav-link', { active: isActive(n.href) }]}>
          {n.label}
        </a>
      ))}
    </nav>

    <div class="actions">
      <a href={switchHref} class="lang-switch" aria-label={L.langSwitch.aria} hreflang={otherLang}>
        {L.langSwitch.label}
      </a>
      <a href={`tel:${site.phone}`} class="phone">
        <Icon name="phone" />
        <span>{site.phoneDisplay}</span>
      </a>
      <a href={site.portalUrl} class="btn btn-ghost sm" rel="noopener" target="_blank">{L.portal}</a>
      <a href={waHref} class="btn btn-primary sm" rel="noopener" target="_blank">
        <Icon name="wa" /> {L.whatsapp}
      </a>
    </div>

    <button class="menu-toggle" aria-label={L.menuOpen} aria-expanded="false" id="menuToggle">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="mobile-menu" id="mobileMenu" hidden>
    {nav.map((n) => <a href={n.href} class="m-link">{n.label}</a>)}
    <a href={site.portalUrl} class="m-link" rel="noopener" target="_blank">{L.portal}</a>
    <a href={switchHref} class="m-link" hreflang={otherLang}>{L.langSwitch.label} · {otherLang === 'en' ? 'English' : 'Türkçe'}</a>
    <div class="m-actions">
      <a href={`tel:${site.phone}`} class="btn btn-ghost"><Icon name="phone" /> {site.phoneDisplay}</a>
      <a href={waHref} class="btn btn-primary" rel="noopener" target="_blank"><Icon name="wa" /> {L.whatsapp}</a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid var(--line);
  }
  .bar {
    display: flex;
    align-items: center;
    gap: 1rem;
    height: 68px;
  }
  .brand { text-decoration: none; }
  .nav {
    display: flex;
    gap: 0.35rem;
    margin-inline: auto;
  }
  .nav-link {
    padding: 0.5rem 0.85rem;
    border-radius: 8px;
    color: var(--ink);
    font-weight: 500;
    font-size: 0.96rem;
  }
  .nav-link:hover { background: var(--wash); text-decoration: none; }
  .nav-link.active { color: var(--blurple); }
  .actions {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .phone {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--ink);
    font-weight: 600;
    font-size: 0.95rem;
    white-space: nowrap;
  }
  .phone :global(svg) { width: 18px; height: 18px; color: var(--blurple); }
  .lang-switch {
    display: inline-flex; align-items: center; justify-content: center;
    min-width: 34px; height: 34px; padding: 0 0.5rem;
    border: 1px solid var(--line); border-radius: 8px;
    color: var(--ink); font-weight: 600; font-size: 0.85rem;
    letter-spacing: 0.02em;
  }
  .lang-switch:hover { background: var(--wash); border-color: var(--blurple); color: var(--blurple); text-decoration: none; }
  .btn.sm { padding: 0.55rem 1rem; font-size: 0.9rem; }
  .btn.sm :global(svg) { width: 17px; height: 17px; }

  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: 0;
    cursor: pointer;
    padding: 8px;
    margin-left: auto;
  }
  .menu-toggle span {
    width: 24px; height: 2px;
    background: var(--ink);
    border-radius: 2px;
    transition: 0.2s;
  }

  .mobile-menu {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 0.75rem var(--pad) 1.25rem;
    border-top: 1px solid var(--line);
    background: var(--white);
  }
  .mobile-menu[hidden] { display: none; }
  .m-link {
    padding: 0.75rem 0.5rem;
    color: var(--ink);
    font-weight: 500;
    border-bottom: 1px solid var(--line);
  }
  .m-actions {
    display: grid;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  @media (max-width: 900px) {
    .nav, .actions { display: none; }
    .menu-toggle { display: flex; }
  }
  @media (min-width: 901px) {
    .mobile-menu { display: none !important; }
  }
</style>

<script>
  const t = document.getElementById('menuToggle');
  const m = document.getElementById('mobileMenu');
  t?.addEventListener('click', () => {
    const open = m?.hasAttribute('hidden');
    if (open) m?.removeAttribute('hidden');
    else m?.setAttribute('hidden', '');
    t.setAttribute('aria-expanded', String(open));
  });
</script>
