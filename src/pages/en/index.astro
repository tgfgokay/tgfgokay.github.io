---
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import Icon from '../../components/Icon.astro';
import ContactSection from '../../components/ContactSection.astro';
import { site } from '../../data/site';
import portrait from '../../assets/images/gokay-portrait.jpg';
import { servicesEn, whyPointsEn, processStepsEn, pages } from '../../i18n/en';
import { ui } from '../../i18n/ui';

const L = ui.en;
const P = pages.home;
const waHref = `https://wa.me/${site.whatsapp}?text=${encodeURIComponent(L.waText)}`;

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  inLanguage: L.inLanguage,
  mainEntity: P.faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Base
  title={site.name}
  description={P.metaDescription}
  path="/en/"
  lang="en"
  altPath="/"
  jsonLd={[faqSchema]}
>
  <!-- 1) HERO -->
  <section class="hero">
    <div class="container">
      <span class="pill">
        <Icon name="pin" /> {P.pill}
      </span>
      <h1>{P.h1pre} <span class="grad-text">{P.h1grad}</span> {P.h1post}</h1>
      <p class="lede">{P.lede}</p>
      <div class="hero-cta">
        <a href={waHref} class="btn btn-primary" rel="noopener" target="_blank">
          <Icon name="chat" /> {L.freeCall}
        </a>
        <a href="/en/services/company-formation/" class="btn btn-ghost">
          {P.ctaSecondary} <Icon name="arrow" />
        </a>
      </div>
      <div class="trust-strip hero-trust">
        {P.trust.map((t) => <span>{t}</span>)}
      </div>
    </div>
    <div class="hero-glow" aria-hidden="true"></div>
  </section>

  <!-- 2) SERVICES -->
  <section class="section bg-wash">
    <div class="container">
      <span class="eyebrow">{P.servicesEyebrow}</span>
      <h2>{P.servicesHeading}</h2>
      <p class="lede">{P.servicesLede}</p>
      <div class="grid grid-3 svc-grid">
        {servicesEn.map((s) => (
          <a href={`/en/services/${s.slug}/`} class="card svc-card">
            <span class="icon-badge"><Icon name={s.icon} /></span>
            <h3>{s.title}</h3>
            <p>{s.short}</p>
            <span class="detay">{L.detay} <Icon name="arrow" /></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 3) WHY -->
  <section class="section">
    <div class="container">
      <span class="eyebrow">{P.whyEyebrow}</span>
      <h2>{P.whyHeading}</h2>
      <div class="grid grid-3 why-grid">
        {whyPointsEn.map((w, i) => (
          <div class="why">
            <span class="icon-badge"><Icon name={['chat', 'shield', 'eye'][i]} /></span>
            <h3>{w.title}</h3>
            <p>{w.text}</p>
          </div>
        ))}
      </div>

      <div class="person-band">
        <Image src={portrait} alt="Gökay Gül — Certified Public Accountant (SMMM)" width={96} height={96} class="person-photo" loading="lazy" />
        <div class="person-info">
          <strong>Gökay Gül</strong>
          <span>Certified Public Accountant (SMMM) · TÜRMOB licensed · İSMMMO member</span>
        </div>
        <a href="/en/about/" class="btn btn-ghost person-btn">
          About me <Icon name="arrow" />
        </a>
      </div>

      <p class="fee-note">
        <strong>Fees:</strong> set together within the İSMMMO minimum tariff framework, based on
        your business volume and workload. The first call is always free.
      </p>
    </div>
  </section>

  <!-- 4) PROCESS -->
  <section class="section bg-wash">
    <div class="container">
      <span class="eyebrow">{P.processEyebrow}</span>
      <h2>{P.processHeading}</h2>
      <ol class="steps">
        {processStepsEn.map((p, i) => (
          <li class="step">
            <span class="step-no">{i + 1}</span>
            <h3>{p.title}</h3>
            <p>{p.text}</p>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <!-- 5) CLIENT PORTAL -->
  <section class="section">
    <div class="container">
      <div class="portal">
        <div>
          <span class="eyebrow" style="color:#fff">{P.portalEyebrow}</span>
          <h2>{P.portalHeading}</h2>
          <p>{P.portalText}</p>
        </div>
        <a href={site.portalUrl} class="btn btn-ghost" rel="noopener" target="_blank">
          {P.portalBtn} <Icon name="arrow" />
        </a>
      </div>
    </div>
  </section>

  <!-- 6) CONTACT -->
  <ContactSection lang="en" />
</Base>

<style>
  /* HERO */
  .hero {
    position: relative;
    overflow: hidden;
    padding-block: clamp(3.5rem, 9vw, 7rem);
    background: linear-gradient(180deg, var(--wash) 0%, var(--white) 100%);
  }
  .hero .pill { margin-bottom: 1.5rem; }
  .hero h1 { max-width: 16ch; }
  .hero .lede { margin-top: 1.25rem; max-width: 56ch; }
  .hero-cta { display: flex; gap: 0.85rem; flex-wrap: wrap; margin-top: 2rem; }
  .hero-trust { margin-top: 2.25rem; }
  .hero-glow {
    position: absolute;
    top: -20%;
    right: -10%;
    width: 45vw;
    height: 45vw;
    max-width: 620px;
    max-height: 620px;
    background: radial-gradient(circle, rgba(138, 123, 255, 0.28), transparent 65%);
    filter: blur(30px);
    pointer-events: none;
  }

  /* SERVICE CARDS */
  .svc-grid { margin-top: 2rem; }
  .svc-card { display: flex; flex-direction: column; text-decoration: none; color: var(--ink); }
  .svc-card:hover { text-decoration: none; }
  .svc-card p { color: var(--slate); font-size: 0.95rem; flex: 1; }
  .detay {
    display: inline-flex; align-items: center; gap: 0.35rem;
    color: var(--blurple); font-weight: 600; font-size: 0.9rem; margin-top: 0.5rem;
  }
  .detay :global(svg) { width: 16px; height: 16px; transition: transform 0.15s ease; }
  .svc-card:hover .detay :global(svg) { transform: translateX(3px); }

  /* WHY */
  .why-grid { margin-top: 2rem; }
  .why h3 { margin-top: 0.25rem; }
  .why p { color: var(--slate); font-size: 0.96rem; }

  /* PERSON BAND + FEE NOTE */
  .person-band {
    display: flex; align-items: center; gap: 1.15rem; flex-wrap: wrap;
    margin-top: 2.25rem; padding: 1.25rem 1.5rem;
    background: var(--wash); border: 1px solid var(--line); border-radius: var(--radius);
  }
  .person-photo {
    width: 72px; height: 72px; border-radius: 50%;
    object-fit: cover; flex: none; display: block;
    border: 2px solid var(--white); box-shadow: 0 2px 10px rgba(26, 31, 54, 0.12);
  }
  .person-info { display: flex; flex-direction: column; gap: 0.15rem; flex: 1; min-width: 220px; }
  .person-info strong { color: var(--ink); font-size: 1.05rem; }
  .person-info span { color: var(--slate); font-size: 0.92rem; }
  .person-btn { white-space: nowrap; }
  .fee-note {
    margin: 1.25rem 0 0; color: var(--slate); font-size: 0.95rem; max-width: 72ch;
  }
  .fee-note strong { color: var(--ink); }

  /* PROCESS */
  .steps {
    list-style: none; margin: 2rem 0 0; padding: 0;
    display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1.25rem;
    counter-reset: step;
  }
  .step {
    position: relative;
    background: var(--white);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.5rem;
  }
  .step-no {
    display: grid; place-items: center;
    width: 38px; height: 38px; border-radius: 10px;
    background: var(--grad); color: #fff; font-weight: 700;
    margin-bottom: 0.9rem;
  }
  .step h3 { font-size: 1.05rem; }
  .step p { color: var(--slate); font-size: 0.93rem; margin: 0; }

  /* PORTAL */
  .portal {
    background: var(--grad);
    color: #fff;
    border-radius: var(--radius);
    padding: clamp(1.75rem, 4vw, 2.75rem);
    display: flex; align-items: center; justify-content: space-between;
    gap: 1.5rem; flex-wrap: wrap;
  }
  .portal h2 { color: #fff; margin-bottom: 0.5rem; }
  .portal p { color: rgba(255,255,255,0.9); margin: 0; max-width: 52ch; }
  .portal .btn-ghost { background: #fff; color: var(--indigo); border-color: #fff; white-space: nowrap; }
  .portal .btn-ghost:hover { background: var(--wash); color: var(--indigo); }
</style>
