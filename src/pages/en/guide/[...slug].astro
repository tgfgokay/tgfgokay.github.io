---
import { getCollection, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../../layouts/Base.astro';
import Icon from '../../../components/Icon.astro';
import CtaStrip from '../../../components/CtaStrip.astro';
import { site } from '../../../data/site';
import { servicesEn, pages, rehberToGuideSlug } from '../../../i18n/en';
import avatar from '../../../assets/images/gokay-avatar.jpg';

const P = pages.guide;

// Guide (EN) slug → Rehber (TR) slug (ters eşleme) — hreflang + dil değiştirici.
const guideToRehberSlug: Record<string, string> = Object.fromEntries(
  Object.entries(rehberToGuideSlug).map(([tr, en]) => [en, tr])
);

export async function getStaticPaths() {
  const posts = await getCollection('guide', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

interface Props { post: CollectionEntry<'guide'> }
const { post } = Astro.props;
const { Content } = await post.render();

const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

const related = post.data.relatedService
  ? servicesEn.find((s) => s.slug === post.data.relatedService)
  : undefined;

const url = `${site.url}/en/guide/${post.slug}/`;
const cover = `/guide-covers/${post.slug}.png`;

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url + '/en/' },
    { '@type': 'ListItem', position: 2, name: 'Guide', item: site.url + '/en/guide/' },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: url },
  ],
};
const article = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  dateModified: (post.data.updated ?? post.data.date).toISOString(),
  image: site.url + cover,
  author: {
    '@id': site.url + '/#gokay',
    '@type': 'Person',
    name: site.personName,
    jobTitle: 'Certified Public Accountant (SMMM)',
    url: site.url + '/en/about/',
  },
  publisher: { '@id': site.url + '/#business' },
  mainEntityOfPage: url,
  inLanguage: 'en',
};
---
<Base
  title={post.data.title}
  description={post.data.description}
  path={`/en/guide/${post.slug}/`}
  lang="en"
  altPath={guideToRehberSlug[post.slug] ? `/rehber/${guideToRehberSlug[post.slug]}/` : undefined}
  jsonLd={[breadcrumb, article]}
  ogType="article"
  ogImage={cover}
>
  <article class="section">
    <div class="container narrow">
      <nav class="crumb" aria-label="breadcrumb">
        <a href="/en/">Home</a> <span>/</span>
        <a href="/en/guide/">Guide</a> <span>/</span> {post.data.title}
      </nav>

      <img src={cover} alt={post.data.title} class="cover" width="1200" height="630" loading="eager" />

      <h1>{post.data.title}</h1>
      <div class="byline">
        <Image src={avatar} alt="Gökay Gül" width={44} height={44} class="ava" loading="lazy" />
        <div>
          <strong>{site.personName}</strong> · Certified Public Accountant (SMMM)<br />
          <span class="meta">{fmt(post.data.date)}{post.data.updated ? ` · updated ${fmt(post.data.updated)}` : ''}</span>
        </div>
      </div>

      <div class="prose">
        <Content />
      </div>

      {related && (
        <aside class="related">
          <div>
            <span class="eyebrow">{P.relatedEyebrow}</span>
            <h2>{related.title}</h2>
            <p>{related.short}</p>
          </div>
          <a href={`/en/services/${related.slug}/`} class="btn btn-primary">
            {pages.services.detail} <Icon name="arrow" />
          </a>
        </aside>
      )}

      <a href="/en/guide/" class="back"><Icon name="arrow" /> {P.allPosts}</a>
    </div>
  </article>

  <CtaStrip lang="en" />
</Base>

<style>
  .narrow { max-width: 720px; }
  .crumb { font-size: 0.85rem; color: var(--slate); margin-bottom: 1.25rem; }
  .crumb a { color: var(--slate); }
  .crumb span { margin: 0 0.4rem; }

  .cover {
    width: 100%; height: auto; display: block;
    border-radius: var(--radius); margin-bottom: 2rem;
    border: 1px solid var(--line);
  }

  .byline {
    display: flex; align-items: center; gap: 0.75rem;
    padding-bottom: 1.5rem; margin-bottom: 2rem;
    border-bottom: 1px solid var(--line);
    font-size: 0.92rem;
  }
  .ava {
    width: 44px; height: 44px; border-radius: 50%;
    object-fit: cover; flex: none; display: block;
  }
  .byline strong { color: var(--ink); }
  .byline .meta { color: var(--slate); }

  /* PROSE typography */
  .prose { font-size: 1.06rem; line-height: 1.75; color: #2a3050; }
  .prose :global(h2) { font-size: 1.5rem; margin: 2.25rem 0 0.75rem; }
  .prose :global(h3) { font-size: 1.2rem; margin: 1.75rem 0 0.5rem; }
  .prose :global(p) { margin: 0 0 1.15rem; }
  .prose :global(ul), .prose :global(ol) { margin: 0 0 1.25rem; padding-left: 1.35rem; }
  .prose :global(li) { margin-bottom: 0.5rem; }
  .prose :global(a) { color: var(--blurple); font-weight: 500; text-decoration: underline; text-underline-offset: 2px; }
  .prose :global(strong) { color: var(--ink); }
  .prose :global(hr) { border: 0; border-top: 1px solid var(--line); margin: 2rem 0; }
  .prose :global(blockquote) {
    margin: 1.5rem 0; padding: 0.85rem 1.25rem;
    background: var(--wash); border-left: 3px solid var(--violet);
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
    color: var(--slate); font-size: 0.96rem;
  }
  .prose :global(blockquote p) { margin: 0; }

  .related {
    display: flex; align-items: center; justify-content: space-between; gap: 1.5rem;
    flex-wrap: wrap;
    margin-top: 2.5rem; padding: 1.75rem;
    background: var(--wash); border: 1px solid var(--line); border-radius: var(--radius);
  }
  .related h2 { font-size: 1.25rem; margin: 0.25rem 0 0.35rem; }
  .related p { margin: 0; color: var(--slate); font-size: 0.95rem; max-width: 46ch; }
  .related .btn { white-space: nowrap; }

  .back {
    display: inline-flex; align-items: center; gap: 0.4rem;
    margin-top: 2.5rem; color: var(--slate); font-weight: 500; font-size: 0.92rem;
  }
  .back :global(svg) { width: 16px; height: 16px; transform: rotate(180deg); }
</style>
