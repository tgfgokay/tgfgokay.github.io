---
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import Icon from '../../components/Icon.astro';
import CtaStrip from '../../components/CtaStrip.astro';
import { site } from '../../data/site';
import { whyPointsEn, pages } from '../../i18n/en';
import portrait from '../../assets/images/gokay-portrait.jpg';

const P = pages.about;

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url + '/en/' },
    { '@type': 'ListItem', position: 2, name: 'About', item: site.url + '/en/about/' },
  ],
};

// Person + ProfilePage — author/founder identity (E-E-A-T). Entity signal for
// AI search: who, which profession, which chamber, where.
const person = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': site.url + '/#gokay',
  name: site.personName,
  jobTitle: 'Certified Public Accountant (SMMM)',
  description: P.personDesc,
  url: site.url + '/en/about/',
  image: new URL('/marka/tgf-emblem.svg', site.url).href,
  worksFor: { '@id': site.url + '/#business' },
  memberOf: { '@type': 'Organization', name: site.chamber },
  knowsAbout: [
    'SME accounting',
    'Company formation',
    'Accounting and payroll',
    'Tax returns and planning',
    'Incentives and KOSGEB',
    'Technopark and R&D',
    'Foreign investor advisory',
  ],
  hasCredential: {
    '@type': 'EducationalOccupationalCredential',
    credentialCategory: 'Certified Public Accountant (SMMM)',
    recognizedBy: { '@type': 'Organization', name: 'TÜRMOB' },
  },
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Şişli',
    addressRegion: 'İstanbul',
    addressCountry: 'TR',
  },
  sameAs: [site.linkedin, site.gokaygul],
};

const profilePage = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  mainEntity: { '@id': site.url + '/#gokay' },
  about: { '@id': site.url + '/#gokay' },
};
---
<Base title="About" description={P.metaDescription} path="/en/about/" lang="en" altPath="/hakkimizda/" jsonLd={[breadcrumb, person, profilePage]}>
  <section class="section">
    <div class="container">
      <nav class="crumb" aria-label="breadcrumb">
        <a href="/en/">Home</a> <span>/</span> About
      </nav>
      <span class="eyebrow">{P.eyebrow}</span>
      <h1>{P.h1}</h1>
      <p class="lede">{P.lede}</p>

      <div class="intro-grid">
        <figure class="portrait">
          <Image
            src={portrait}
            alt="Gökay Gül — Certified Public Accountant (SMMM)"
            widths={[400, 640, 800]}
            sizes="(max-width: 800px) 320px, 400px"
            loading="eager"
          />
          <figcaption class="portrait-cap">{P.portraitCap}</figcaption>
        </figure>

        <div class="note">
          <h2>{P.noteHeading}</h2>
          {P.note.map((para) => <p>{para}</p>)}
          <p class="sign">{P.sign}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- BY THE NUMBERS / TRUST -->
  <section class="section bg-wash">
    <div class="container">
      <span class="eyebrow">{P.statsEyebrow}</span>
      <h2>{P.statsHeading}</h2>
      <div class="grid grid-4 stat-grid">
        {P.stats.map((s) => (
          <div class="card stat">
            <span class="icon-badge"><Icon name={s.icon} /></span>
            <strong>{s.big}</strong>
            <span>{s.small}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- MY VALUES -->
  <section class="section">
    <div class="container">
      <span class="eyebrow">{P.valuesEyebrow}</span>
      <h2>{P.valuesHeading}</h2>
      <div class="grid grid-3 val-grid">
        {whyPointsEn.map((w, i) => (
          <div class="card val">
            <span class="icon-badge"><Icon name={['chat', 'eye', 'shield'][i]} /></span>
            <h3>{w.title}</h3>
            <p>{w.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- EXPERTISE -->
  <section class="section bg-wash">
    <div class="container">
      <span class="eyebrow">{P.expEyebrow}</span>
      <h2>{P.expHeading}</h2>
      <div class="tags">
        {P.expertise.map((t) => <span class="tag">{t}</span>)}
      </div>
    </div>
  </section>

  <CtaStrip heading={P.ctaHeading} lang="en" />
</Base>

<style>
  .crumb { font-size: 0.88rem; color: var(--slate); margin-bottom: 1rem; }
  .crumb a { color: var(--slate); }
  .crumb span { margin: 0 0.4rem; }

  .intro-grid {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 2.5rem;
    margin-top: 2.5rem;
    align-items: start;
  }
  .portrait {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: var(--radius);
    background: var(--wash);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
    margin: 0;
  }
  .portrait :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 12%;
    display: block;
  }
  .portrait-cap {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    margin: 0;
    padding: 0.75rem 1rem;
    font-size: 0.85rem;
    color: #fff;
    font-weight: 500;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.55), transparent);
  }
  .note h2 { margin-bottom: 0.75rem; }
  .note p { color: var(--slate); }
  .note .sign { color: var(--ink); font-weight: 600; margin-top: 1rem; }

  .stat-grid { margin-top: 1.75rem; }
  .stat { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 0.15rem; }
  .stat .icon-badge { margin-bottom: 0.75rem; }
  .stat strong { font-size: 1.35rem; color: var(--ink); }
  .stat span { color: var(--slate); font-size: 0.9rem; }

  .val-grid { margin-top: 1.75rem; }
  .val h3 { margin-top: 0.25rem; }
  .val p { color: var(--slate); font-size: 0.96rem; margin: 0; }

  .tags { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-top: 1.5rem; }
  .tag {
    padding: 0.5rem 1rem;
    border-radius: 999px;
    background: #fff;
    border: 1px solid var(--line);
    font-weight: 500;
    font-size: 0.92rem;
    color: var(--indigo);
  }

  @media (max-width: 820px) {
    .intro-grid { grid-template-columns: 1fr; }
    .portrait { max-width: 320px; }
  }
</style>
