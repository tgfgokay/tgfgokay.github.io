---
import Base from '../../layouts/Base.astro';
import ContactSection from '../../components/ContactSection.astro';
import { site } from '../../data/site';
import { pages } from '../../i18n/en';

const P = pages.contact;

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.url + '/en/' },
    { '@type': 'ListItem', position: 2, name: 'Contact', item: site.url + '/en/contact/' },
  ],
};
---
<Base title="Contact" description={P.metaDescription} path="/en/contact/" lang="en" altPath="/iletisim/" jsonLd={[breadcrumb]}>
  <section class="page-head">
    <div class="container">
      <nav class="crumb" aria-label="breadcrumb">
        <a href="/en/">Home</a> <span>/</span> Contact
      </nav>
      <h1>{P.h1}</h1>
      <p class="lede">{P.lede}</p>
    </div>
  </section>

  <ContactSection heading={P.contactHeading} eyebrow="" lang="en" />
</Base>

<style>
  .page-head { padding-top: clamp(2.5rem, 6vw, 4rem); }
  .crumb { font-size: 0.88rem; color: var(--slate); margin-bottom: 1rem; }
  .crumb a { color: var(--slate); }
  .crumb span { margin: 0 0.4rem; }
</style>
