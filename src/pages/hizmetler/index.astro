---
import Base from '../../layouts/Base.astro';
import Icon from '../../components/Icon.astro';
import CtaStrip from '../../components/CtaStrip.astro';
import { site, services } from '../../data/site';

const description =
  'TGF Mali Müşavirlik hizmetleri: şirket kuruluşu, muhasebe & bordro, beyanname & vergi, teşvik & KOSGEB, teknopark & Ar-Ge ve danışmanlık. İstanbul geneli.';

const breadcrumb = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Ana Sayfa', item: site.url + '/' },
    { '@type': 'ListItem', position: 2, name: 'Hizmetler', item: site.url + '/hizmetler/' },
  ],
};
---
<Base title="Hizmetler" description={description} path="/hizmetler/" altPath="/en/services/" jsonLd={[breadcrumb]}>
  <section class="section">
    <div class="container">
      <nav class="crumb" aria-label="breadcrumb">
        <a href="/">Ana Sayfa</a> <span>/</span> Hizmetler
      </nav>
      <span class="eyebrow">Hizmetler</span>
      <h1>İşletmenizin her aşamasında yanınızdayım</h1>
      <p class="lede">
        Kuruluştan büyümeye kadar ihtiyacınız olan mali işleri tek çatı altında topladım.
        Aşağıdan ilgilendiğiniz başlığa göz atın; sorunuz olursa bir telefon kadar yakınım.
      </p>

      <div class="grid grid-2 svc-grid">
        {services.map((s) => (
          <a href={`/hizmetler/${s.slug}/`} class="card svc-card">
            <span class="icon-badge"><Icon name={s.icon} /></span>
            <div>
              <h2>{s.title}</h2>
              <p>{s.summary}</p>
              <span class="detay">Detaya bak <Icon name="arrow" /></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CtaStrip />
</Base>

<style>
  .crumb { font-size: 0.88rem; color: var(--slate); margin-bottom: 1rem; }
  .crumb a { color: var(--slate); }
  .crumb span { margin: 0 0.4rem; }
  .svc-grid { margin-top: 2.25rem; }
  .svc-card { display: flex; gap: 1.1rem; align-items: flex-start; text-decoration: none; color: var(--ink); }
  .svc-card:hover { text-decoration: none; }
  .svc-card .icon-badge { flex: none; margin-bottom: 0; }
  .svc-card h2 { font-size: 1.25rem; margin-bottom: 0.4rem; }
  .svc-card p { color: var(--slate); font-size: 0.95rem; }
  .detay {
    display: inline-flex; align-items: center; gap: 0.35rem;
    color: var(--blurple); font-weight: 600; font-size: 0.9rem;
  }
  .detay :global(svg) { width: 16px; height: 16px; }
</style>
